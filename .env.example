# .env.example
GEMINI_API_KEY=your_gemini_api_key_here
# 텍스트 생성 - SNS 콘텐츠 (속도+품질 밸런스)
GEMINI_TEXT_MODEL=gemini-2.5-flash
# 단순 분류/분석 - Stage 1 트렌드 수집 (가성비 최우선, Gemini 3.1 Flash Lite)
GEMINI_LITE_MODEL=gemini-3.1-flash-lite-preview
# 이미지 생성 - Nano Banana 2 (텍스트→이미지 특화)
GEMINI_IMAGE_MODEL=nano-banana-pro-preview

# Meta Graph API (Instagram + Threads) - Phase 2에서 추가
META_ACCESS_TOKEN=your_meta_access_token
INSTAGRAM_USER_ID=your_ig_user_id
THREADS_USER_ID=your_threads_user_id

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
